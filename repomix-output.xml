              <span style={{fontSize:18, fontWeight:800, color:'#1B2F5E'}}>{orderDetail.total ? `$${Number(orderDetail.total).toLocaleString('es-AR')}` : '—'}</span>
            </div>
          </div>
        </div>
      )}

      {/* MODAL CONFIRMAR */}
      {confirmModal.open && (
