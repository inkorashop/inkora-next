                      onChange={e => updateTag(tag.id, 'description', e.target.value)}
                      onBlur={() => commitTagUpdate(tag.id)}
                    />
                  </div>
                ))}
              </div>

              <button
                style={{...s.btnPrimary, padding:'9px 14px', fontSize:13, width:'100%'}}
