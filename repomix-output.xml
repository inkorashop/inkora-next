                </div>
                <div>
                  <label style={lbl}>Confirmar contraseña</label>
                  <input type="password" style={inp} value={confirmPassword} onChange={e => setConfirmPassword(e.target.value)} placeholder="Repetí la contraseña" />
                </div>
              </div>
