  async function saveCategoryRename() {
    const edit = editingCategory;
    if (!edit || savingCategory) return;

    const newName = edit.value.trim();
    if (!newName || newName === edit.oldName) {
      setEditingCategory(null);
      return;
    }

    setSavingCategory(true);
    const product = products.find(p => p.id === edit.productId);
    const currentCategories = Array.isArray(product?.categories) && product.categories.length > 0
      ? product.categories
      : [...new Set((designsByProduct[edit.productId] || []).map(d => d.category).filter(c => c && c !== 'Sin categoria' && c !== 'Sin categoría'))];
    const nextCategories = [...new Set(currentCategories.map(c => c === edit.oldName ? newName : c))];
    const currentColors = product?.category_colors || {};
    const nextColors = { ...currentColors };

    if (Object.prototype.hasOwnProperty.call(nextColors, edit.oldName)) {
      nextColors[newName] = nextColors[newName] || nextColors[edit.oldName];
      delete nextColors[edit.oldName];
    }

    const previousProducts = products;
    const previousDesignsByProduct = designsByProduct;
    updateLocalCategoryName(edit.productId, edit.oldName, newName, nextCategories, nextColors);
    if (filter === edit.oldName) setFilter(newName);
    setEditingCategory(null);

    try {
      const { error: productError } = await supabase
        .from('products')
        .update({ categories: nextCategories, category_colors: nextColors })
        .eq('id', edit.productId);
      if (productError) throw productError;

      const { data: productDesigns, error: designsError } = await supabase
        .from('designs')
        .select('id, category, categories')
        .eq('product_id', edit.productId)
        .limit(10000);
      if (designsError) throw designsError;

      const updates = (productDesigns || [])
        .filter(d => d.category === edit.oldName || (Array.isArray(d.categories) && d.categories.includes(edit.oldName)))
        .map(d => {
          const nextDesignCategories = Array.isArray(d.categories)
            ? [...new Set(d.categories.map(c => c === edit.oldName ? newName : c))]
            : d.categories;
          const payload = {
            category: d.category === edit.oldName ? newName : d.category,
          };
          if (Array.isArray(nextDesignCategories)) payload.categories = nextDesignCategories;
          return supabase
            .from('designs')
            .update(payload)
            .eq('id', d.id);
        });

      const results = await Promise.all(updates);
      const failed = results.find(result => result.error);
      if (failed) throw failed.error;
    } catch (error) {
      setProducts(previousProducts);
      setDesignsByProduct(previousDesignsByProduct);
      if (filter === newName) setFilter(edit.oldName);
      alert('No se pudo renombrar la categoria. Intenta de nuevo.');
    } finally {
      setSavingCategory(false);
    }
  }

