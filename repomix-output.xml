      const currIdx = visible.findIndex(d => d.id === id);
      if (lastIdx !== -1 && currIdx !== -1) {
        const [start, end] = lastIdx < currIdx ? [lastIdx, currIdx] : [currIdx, lastIdx];
        setSelectedIds(new Set(visible.slice(start, end + 1).map(d => d.id)));
